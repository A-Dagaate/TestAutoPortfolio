            new[] { "Gherkin feature file authoring", "Step definition binding", "Hooks, tags & test filtering", "Living documentation output" },
            new[] { "SpecFlow", "C#", "NUnit", "Azure DevOps" },
            "https://github.com/A-Dagaate",
