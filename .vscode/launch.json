{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Blazor WebAssembly",
      "type": "blazorwasm",
      "request": "launch",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Launch & Watch (Hot Reload)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "watch",
      "program": "dotnet",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ]
}
